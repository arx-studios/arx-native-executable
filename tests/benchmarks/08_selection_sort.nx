void selectionSort(int[] arr) {
    for (int i = 0; i < arr.length - 1; i = i + 1) {
        int minIdx = i;
        for (int j = i + 1; j < arr.length; j = j + 1) {
            if (arr[j] < arr[minIdx]) {
                minIdx = j;
            }
        }
        int tmp = arr[i];
        arr[i] = arr[minIdx];
        arr[minIdx] = tmp;
    }
}

void main() {
    int[] arr = [5, 2, 4, 1, 3];
    selectionSort(arr);
    print(arr[0]);
    print(arr[1]);
    print(arr[2]);
    print(arr[3]);
    print(arr[4]);
}
