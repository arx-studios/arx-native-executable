void twoSumSorted(int[] arr, int target, int[] result) {
    int i = 0;
    int j = arr.length - 1;
    while (i < j) {
        int sum = arr[i] + arr[j];
        if (sum == target) {
            result[0] = i;
            result[1] = j;
            return;
        } else if (sum < target) {
            i = i + 1;
        } else {
            j = j - 1;
        }
    }
}

void main() {
    int[] nums = [2, 7, 11, 15];
    int[] result = new int[2];
    twoSumSorted(nums, 9, result);
    print(result[0]);
    print(result[1]);
}
