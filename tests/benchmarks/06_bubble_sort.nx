void bubbleSort(int[] arr) {
    for (int i = 0; i < arr.length - 1; i = i + 1) {
        for (int j = 0; j < arr.length - 1 - i; j = j + 1) {
            if (arr[j] > arr[j + 1]) {
                int tmp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = tmp;
            }
        }
    }
}

void main() {
    int[] arr = [5, 2, 4, 1, 3];
    bubbleSort(arr);
    print(arr[0]);
    print(arr[1]);
    print(arr[2]);
    print(arr[3]);
    print(arr[4]);
}
