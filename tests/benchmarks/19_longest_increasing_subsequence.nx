int lengthOfLIS(int[] nums) {
    int n = nums.length;
    int[] dp = new int[n];
    int i = 0;
    while (i < n) {
        dp[i] = 1;
        i = i + 1;
    }
    int best = 0;
    for (int j = 0; j < n; j = j + 1) {
        for (int k = 0; k < j; k = k + 1) {
            if (nums[k] < nums[j] && dp[k] + 1 > dp[j]) {
                dp[j] = dp[k] + 1;
            }
        }
        if (dp[j] > best) {
            best = dp[j];
        }
    }
    return best;
}

void main() {
    int[] nums = [10, 9, 2, 5, 3, 7, 101, 18];
    print(lengthOfLIS(nums));
}
