int knapsack(int[] weights, int[] values, int capacity) {
    int n = weights.length;
    int width = capacity + 1;
    int[] dp = new int[(n + 1) * width];
    for (int i = 1; i <= n; i = i + 1) {
        for (int w = 0; w <= capacity; w = w + 1) {
            int without = dp[(i - 1) * width + w];
            int best = without;
            if (weights[i - 1] <= w) {
                int withItem = values[i - 1] + dp[(i - 1) * width + (w - weights[i - 1])];
                if (withItem > best) {
                    best = withItem;
                }
            }
            dp[i * width + w] = best;
        }
    }
    return dp[n * width + capacity];
}

void main() {
    int[] weights = [1, 3, 4, 5];
    int[] values = [1, 4, 5, 7];
    print(knapsack(weights, values, 7));
}
