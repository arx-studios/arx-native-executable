void reverseArray(int[] arr) {
    int i = 0;
    int j = arr.length - 1;
    while (i < j) {
        int tmp = arr[i];
        arr[i] = arr[j];
        arr[j] = tmp;
        i = i + 1;
        j = j - 1;
    }
}

void main() {
    int[] arr = [1, 2, 3, 4, 5];
    reverseArray(arr);
    print(arr[0]);
    print(arr[4]);
}
