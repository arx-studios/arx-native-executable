void merge(int[] arr, int lo, int mid, int hi) {
    int n = hi - lo + 1;
    int[] tmp = new int[n];
    int i = lo;
    int j = mid + 1;
    int k = 0;
    while (i <= mid && j <= hi) {
        if (arr[i] <= arr[j]) {
            tmp[k] = arr[i];
            i = i + 1;
        } else {
            tmp[k] = arr[j];
            j = j + 1;
        }
        k = k + 1;
    }
    while (i <= mid) {
        tmp[k] = arr[i];
        i = i + 1;
        k = k + 1;
    }
    while (j <= hi) {
        tmp[k] = arr[j];
        j = j + 1;
        k = k + 1;
    }
    int m = 0;
    while (m < n) {
        arr[lo + m] = tmp[m];
        m = m + 1;
    }
}

void mergeSort(int[] arr, int lo, int hi) {
    if (lo >= hi) return;
    int mid = lo + (hi - lo) / 2;
    mergeSort(arr, lo, mid);
    mergeSort(arr, mid + 1, hi);
    merge(arr, lo, mid, hi);
}

void main() {
    int[] arr = [5, 2, 4, 1, 3, 9, 6];
    mergeSort(arr, 0, arr.length - 1);
    print(arr[0]);
    print(arr[3]);
    print(arr[6]);
}
